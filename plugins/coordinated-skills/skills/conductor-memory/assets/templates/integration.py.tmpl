#!/usr/bin/env python3
"""
{PROJECT_TITLE} Memory Integration
Generated by the conductor-memory skill on {SESSION_DATE}.

This places a synthesized memory pack into your knowledge system so the next
session can resume with full context. It is intentionally backend-agnostic:

  1. Obsidian vault   - copies the pack into your vault and updates a rolling
                        index (default; always runs).
  2. Claude Code      - updates a "Session Memory" pointer block in a target
                        CLAUDE.md so a fresh Claude Code session loads the
                        resume note automatically.
  3. Vector / MCP     - optional hook. Left as a clearly-marked stub because the
                        exact backend (Chroma, an MCP server, AgentScope, etc.)
                        varies per project. Wire up `push_to_store()` when ready.

Everything below uses only the Python standard library so it runs anywhere
without `pip install`. Run `python integration.py --help` for options.
"""

import argparse
import json
import shutil
from datetime import datetime
from pathlib import Path

# --- Config baked in at generation time (override via CLI flags) --------------
PROJECT_NAME = "{PROJECT_NAME}"
PROJECT_TITLE = "{PROJECT_TITLE}"
SESSION_LABEL = "{SESSION_LABEL}"
DEFAULT_VAULT = Path("{VAULT_PATH}").expanduser()
DEFAULT_MEMORY_SUBDIR = "{MEMORY_SUBDIR}"
DEFAULT_CLAUDE_MD = "{CLAUDE_CODE_MEMORY}"  # may be empty -> skipped
PACK_DIR = Path(__file__).resolve().parent   # this pack lives next to this script


def copy_into_vault(vault: Path, memory_subdir: str) -> Path:
    """Copy this memory pack into the vault's memory directory."""
    dest_root = vault / memory_subdir
    dest_root.mkdir(parents=True, exist_ok=True)
    dest = dest_root / PACK_DIR.name
    if dest.exists():
        shutil.rmtree(dest)
    shutil.copytree(PACK_DIR, dest)
    print(f"  Copied pack -> {dest}")
    return dest


def update_rolling_index(vault: Path, memory_subdir: str, pack_dest: Path) -> None:
    """Maintain a rolling MEMORY_LOG.md listing every session, newest first."""
    log = vault / memory_subdir / "MEMORY_LOG.md"
    rel = pack_dest.relative_to(vault / memory_subdir)
    stamp = datetime.now().strftime("%Y-%m-%d %H:%M")
    label = SESSION_LABEL or pack_dest.name
    line = f"- {stamp} - [[{rel}/MEMORY_INDEX|{label}]]\n"

    header = f"# {PROJECT_TITLE} - Memory Log\n\nNewest sessions first. Each links to that session's MEMORY_INDEX.\n\n"
    if log.exists():
        body = log.read_text()
        if "Newest sessions first" in body:
            body = body.split("\n\n", 2)[-1]  # drop old header, keep entries
    else:
        body = ""
    log.write_text(header + line + body)
    print(f"  Updated rolling log -> {log}")


def update_claude_md(claude_md: Path, pack_dest: Path, vault: Path) -> None:
    """Replace (or append) a managed Session Memory block in a CLAUDE.md."""
    start = "<!-- conductor-memory:start -->"
    end = "<!-- conductor-memory:end -->"
    try:
        rel = pack_dest.relative_to(vault)
    except ValueError:
        rel = pack_dest
    block = (
        f"{start}\n"
        f"## Session Memory ({PROJECT_TITLE})\n\n"
        f"Resume point from the last session. Read the linked index first.\n\n"
        f"- Latest pack: `{rel}/`\n"
        f"- Start here: `{rel}/MEMORY_INDEX.md`\n"
        f"- Updated: {datetime.now().strftime('%Y-%m-%d %H:%M')}\n"
        f"{end}"
    )
    claude_md.parent.mkdir(parents=True, exist_ok=True)
    if claude_md.exists():
        text = claude_md.read_text()
        if start in text and end in text:
            pre = text.split(start)[0]
            post = text.split(end, 1)[1]
            text = pre + block + post
        else:
            text = text.rstrip() + "\n\n" + block + "\n"
    else:
        text = block + "\n"
    claude_md.write_text(text)
    print(f"  Updated Claude Code memory -> {claude_md}")


def push_to_store(pack_dir: Path) -> None:
    """
    OPTIONAL hook for a vector DB / MCP memory server / AgentScope store.

    Left as a stub on purpose. The synthesized, machine-readable inputs are
    already sitting in this pack:
        - {PROJECT_NAME}_memory_seed_data.json  (conversations + state)
        - {PROJECT_NAME}_memory_personality.yaml (persona config)
    Wire your backend in below. Example shape:

        seed = json.loads((pack_dir / f"{PROJECT_NAME}_memory_seed_data.json").read_text())
        for conv in seed["conversations"]:
            store.upsert(id=conv["id"], text=conv.get("summary") or conv.get("user_input", ""),
                         metadata=conv.get("metadata", {}))
    """
    print("  Vector/MCP push skipped (stub - wire up push_to_store() when ready).")


def main() -> None:
    ap = argparse.ArgumentParser(description="Integrate this memory pack into your system.")
    ap.add_argument("--vault", default=str(DEFAULT_VAULT), help="Path to your Obsidian vault.")
    ap.add_argument("--memory-subdir", default=DEFAULT_MEMORY_SUBDIR,
                    help="Subdirectory inside the vault for memory packs.")
    ap.add_argument("--claude-md", default=DEFAULT_CLAUDE_MD,
                    help="CLAUDE.md to update with a resume pointer (blank to skip).")
    ap.add_argument("--push-store", action="store_true",
                    help="Also run the vector/MCP push hook (off by default).")
    ap.add_argument("--dry-run", action="store_true", help="Print actions without writing.")
    args = ap.parse_args()

    vault = Path(args.vault).expanduser()
    print(f"Integrating '{PACK_DIR.name}' into {vault} ...")
    if args.dry_run:
        print("  (dry run - no files written)")
        return

    dest = copy_into_vault(vault, args.memory_subdir)
    update_rolling_index(vault, args.memory_subdir, dest)
    if args.claude_md:
        update_claude_md(Path(args.claude_md).expanduser(), dest, vault)
    if args.push_store:
        push_to_store(dest)
    print("Done. Next session can resume from the MEMORY_INDEX in the vault.")


if __name__ == "__main__":
    main()
